{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Secret": "your-256-bit-secret-key-here-change-in-production"
  },
  "Urls": "http://0.0.0.0:8080",
  "ReverseProxy": {
    "Routes": {
      "auth": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },
      "matchmaking": {
        "ClusterId": "matchmaking-cluster",
        "Match": {
          "Path": "/matchmaking/{**catch-all}"
        },
        "AuthorizationPolicy": "Authenticated"
      },
      "state": {
        "ClusterId": "state-cluster",
        "Match": {
          "Path": "/state/{**catch-all}"
        },
        "AuthorizationPolicy": "Authenticated"
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth": {
            "Address": "http://localhost:8081"
          }
        }
      },
      "matchmaking-cluster": {
        "Destinations": {
          "matchmaking": {
            "Address": "http://localhost:8082"
          }
        }
      },
      "state-cluster": {
        "Destinations": {
          "state": {
            "Address": "http://localhost:8084"
          }
        }
      }
    }
  }
}
